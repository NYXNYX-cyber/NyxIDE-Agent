{
  "name": "nyxide",
  "description": "AI-Powered Desktop IDE with Monaco Editor and Custom AI Agent Integration",
  "author": "NYXNYX-cyber",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && npx electron .",
    "build": "tsc && vite build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.73",
    "@ai-sdk/react": "^3.0.210",
    "@monaco-editor/react": "^4.7.0",
    "ai": "^6.0.208",
    "antd": "^6.4.4",
    "node-pty": "^1.1.0",
    "react": "^19.2.6",
    "react-diff-viewer-continued": "^4.2.2",
    "react-dom": "^19.2.6",
    "react-split-pane": "^3.2.0",
    "uuid": "^14.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.61.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^1.0.4",
    "wait-on": "^9.0.10"
  },
  "main": "src-electron/main.cjs",
  "build": {
    "appId": "com.nyxiside.app",
    "productName": "NyxIDE",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    }
  }
}
